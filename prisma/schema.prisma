generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  songs    Song[]
  sessions Session[]
  requests Request[]
  rules    Ruleset?
  top10Entries Top10Entry[]

  CreditLedger CreditLedger[]
  PlayHistory  PlayHistory[]

  identities Identity[]
  otpCodes   OtpCode[]
}

model Song {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  trackId    String?
  title      String
  artist     String
  artistKey  String
  artworkUrl String?
  explicit   Boolean  @default(false)
  tags       String[] @default([])

  createdAt   DateTime      @default(now())
  Request     Request[]
  PlayHistory PlayHistory[]
  top10Entries Top10Entry[]

  @@index([locationId])
  @@index([artistKey])
  @@index([locationId, trackId])
}

model Session {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  startedAt DateTime @default(now())
  endsAt    DateTime
  createdAt DateTime @default(now())

  requests Request[]
  votes    Vote[]
  top10Entries Top10Entry[]

  @@index([locationId, endsAt])
}

model Request {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  songId String
  song   Song   @relation(fields: [songId], references: [id])

  emailHash  String
  type       RequestType   @default(NEXT)
  status     RequestStatus @default(APPROVED)
  top10Bucket Top10Bucket?

  createdAt    DateTime  @default(now())
  playedAt     DateTime?
  rejectedAt   DateTime?
  rejectReason String?

  votes Vote[]

  @@index([locationId, sessionId])
  @@index([status])
  @@index([sessionId, top10Bucket])
}

model Vote {
  id        String  @id @default(cuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id])

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  emailHash String
  value     Int
  createdAt DateTime @default(now())

  @@index([requestId, emailHash])
  @@index([sessionId, emailHash])
}


model Top10Entry {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id])

  songId     String
  song       Song     @relation(fields: [songId], references: [id])

  bucket         Top10Bucket
  title          String
  artist         String
  artworkUrl     String?
  requestCount   Int      @default(0)
  upvotes        Int      @default(0)
  downvotes      Int      @default(0)
  score          Int      @default(0)
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([locationId, sessionId, bucket, songId])
  @@index([locationId, sessionId, bucket, score])
  @@index([locationId, sessionId, bucket, lastActivityAt])
}

model CreditLedger {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  emailHash String
  delta     Int
  reason    String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([locationId, emailHash])
}

model PlayHistory {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  songId String
  song   Song   @relation(fields: [songId], references: [id])

  artistKey String
  playedAt  DateTime @default(now())

  @@index([locationId, playedAt])
  @@index([locationId, artistKey, playedAt])
  @@index([locationId, songId, playedAt])
}

model Ruleset {
  id         String   @id @default(cuid())
  locationId String   @unique
  location   Location @relation(fields: [locationId], references: [id])

  costRequest  Int @default(1)
  costUpvote   Int @default(1)
  costDownvote Int @default(1)
  costPlayNow  Int @default(5)

  // Pack pricing (cents)
  packTier1PriceCents Int @default(500)
  packTier2PriceCents Int @default(1000)
  packTier3PriceCents Int @default(1500)
  packTier4PriceCents Int @default(2000)

  logoUrl String?

  maxRequestsPerSession    Int @default(1)
  maxVotesPerSession       Int @default(3)
  minSecondsBetweenActions Int @default(10)

  enforceArtistCooldown Boolean @default(true)
  enforceSongCooldown   Boolean @default(true)
  artistCooldownMinutes Int     @default(15)
  songCooldownMinutes   Int     @default(120)

  maxActiveRequestsPerUser   Int    @default(2)
  msgTooManyActiveRequests   String @default("You already have songs waiting in the queue.")
  enableVoting               Boolean @default(true)
  msgExplicit                String @default("Sorry — this song isn’t available here.")
  msgAlreadyRequested        String @default("You’ve already made a request this session.")
  msgArtistCooldown          String @default("Sorry — this artist has played in the last 15 minutes.")
  msgSongCooldown            String @default("Sorry — this song has already been played in the last 2 hours.")
  msgNoCredits               String @default("Not enough credits.")
  maxArtistInQueue           Int    @default(0)
  msgArtistAlreadyQueued     String @default("Sorry, $artist is already queued up on the request list!")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Identity {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  emailHash String
  phoneE164 String?
  phoneHash String?

  deviceId      String?
  smsVerifiedAt DateTime?
  emailOptInAt  DateTime?
  smsOptInAt    DateTime?

  mailchimpStatus String?
  mailchimpError  String?

  welcomeGrantedSessionId String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  pendingCheckouts        PendingCheckout[]

  @@unique([locationId, emailHash])
  @@index([locationId, phoneHash])
  @@index([locationId, deviceId])
}

model OtpCode {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  emailHash String
  phoneE164 String
  phoneHash String

  codeHash    String
  expiresAt   DateTime
  attempts    Int      @default(0)
  maxAttempts Int      @default(6)
  sentAt      DateTime @default(now())

  ipHash   String?
  deviceId String?

  @@index([locationId, phoneHash])
  @@index([locationId, emailHash])
  @@index([expiresAt])
}

model PendingCheckout {
  id          String @id @default(cuid())
  referenceId String @unique

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id])

  location String

  packageKey  String
  credits     Int
  amountCents Int
  currency    String @default("USD")

  createdAt  DateTime  @default(now())
  consumedAt DateTime?
  paymentId  String?   @unique

  @@index([identityId])
}

model ProcessedPayment {
  id String @id @default(cuid())

  paymentId String @unique

  createdAt DateTime @default(now())
}

enum RequestType {
  NEXT
  PLAY_NOW
}

enum RequestStatus {
  APPROVED
  REJECTED
  PLAYED
}

model RedemptionCode {
  id         String   @id @default(cuid())
  locationId String
  code       String
  points     Int
  maxUses    Int      @default(1)
  uses       Int      @default(0)
  expiresAt  DateTime?
  redeemWindowMinutes Int @default(120)
  disabledAt DateTime?
  source     String?
  createdAt  DateTime @default(now())

  usesRel RedemptionCodeUse[]

  @@unique([locationId, code])
  @@index([locationId])
  @@index([expiresAt])
}

model RedemptionCodeUse {
  id         String   @id @default(cuid())
  locationId String
  codeId     String
  emailHash  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  code RedemptionCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([codeId, emailHash])
  @@index([locationId])
  @@index([emailHash])
  @@index([expiresAt])
}

model ScreenMessage {
  id                 String   @id @default(cuid())
  locationId         String
  sessionId          String
  identityId         String?
  emailHash          String
  fromName           String
  messageText        String
  tier               String
  creditsCost        Int
  status             String
  displayDurationSec Int
  sortWeight         Int?

  moderationNotes          String?
  autoTextModerationResult String?
  autoTextModerationReason String?
  autoModeratedAt          DateTime?

  approvedAt         DateTime?
  rejectedAt         DateTime?
  activatedAt        DateTime?
  expiredAt          DateTime?

  approvedBy         String?
  rejectedBy         String?
  refundLedgerId     String?  @unique

  imageOriginalPath     String?
  imagePreviewPath      String?
  imageOriginalMime     String?
  imageSizeBytes        Int?
  imageModerationStatus String?
  imageModerationReason String?
  imageUploadedAt       DateTime?

  usageRightsAccepted   Boolean  @default(false)
  usageRightsAcceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId, sessionId])
  @@index([locationId, sessionId, status, createdAt])
  @@index([locationId, sessionId, approvedAt])
  @@index([status])
  @@index([imageModerationStatus])
}

model MessageRuleset {
  id         String   @id @default(cuid())
  locationId String   @unique

  enabled Boolean
  costBasic Int
  costFeatured Int

  maxMessageChars Int
  maxFromNameChars Int

  displayDurationBasicSec Int
  displayDurationFeaturedSec Int

  approvalRequired Boolean
  autoRefundRejected Boolean

  maxPendingPerIdentity Int

  filterBlockMessage String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum Top10Bucket {
  GENERAL
  ADULT
}
